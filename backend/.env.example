# Copy this file to backend/.env and adjust the values you actually need.
# Every variable is OPTIONAL — sane defaults live in the code.
# Run with `node --env-file=.env dist/main.js` (production) to load them.

# HTTP port the API listens on. Defaults to 3000.
PORT=3000

# Comma-separated list of allowed origins. Defaults to:
#   http://localhost:5173,http://localhost,http://127.0.0.1
CORS_ORIGIN=http://localhost:5173

# Path to the SQLite database file (relative to backend/ unless absolute).
# Defaults to "database.sqlite".
SQLITE_PATH=database.sqlite
