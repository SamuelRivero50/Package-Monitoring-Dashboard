# =============================================================
# .gitignore — PackTrack
# =============================================================

# --- Dependencies ---
node_modules/

# --- Build output ---
dist/
dist-ssr/

# --- Environment (never commit secrets) ---
.env
.env.local
.env.*.local

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS files ---
.DS_Store
Thumbs.db

# --- Editor config ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- TypeScript cache ---
*.tsbuildinfo

# --- Tool caches ---
.eslintcache
*.timestamp-*.mjs

# --- Test artifacts ---
coverage/
__screenshots__/
test-results/
playwright-report/
/cypress/videos/
/cypress/screenshots/
